RAWG_API_KEY=<YOUR-RAWG-API-KEY>
RAWG_BASE_URL=https://api.rawg.io/api
DUCKDB_PATH=<ABSOLUTE-PATH-TO-THIS-DIRECTORY>/game_release.duckdb
RAWG_PAGE_SIZE=40
RAWG_MAX_PAGES_PER_SEGMENT=3
RAWG_REQUEST_TIMEOUT_SECONDS=30
RAWG_REQUEST_RETRY_ATTEMPTS=3
RAWG_REQUEST_RETRY_BACKOFF_SECONDS=1.0
AIRFLOW_HOME=<ABSOLUTE-PATH-TO-THIS-DIRECTORY>/orchestration/airflow
PYTHONPATH=<ABSOLUTE-PATH-TO-THIS-DIRECTORY>/src:<ABSOLUTE-PATH-TO-THIS-DIRECTORY>/orchestration/airflow
